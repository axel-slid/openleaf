{
  "name": "openleaf",
  "version": "0.1.1",
  "productName": "Openleaf",
  "description": "Agent-native desktop workspace for LaTeX papers, PDFs, terminals, and review workflows.",
  "repository": {
    "type": "git",
    "url": "https://github.com/axel-slid/openleaf.git"
  },
  "main": "main.js",
  "bin": {
    "openleaf": "scripts/openleaf-cli.mjs"
  },
  "scripts": {
    "start": "node scripts/start.mjs",
    "dev": "electron \"$PWD\"",
    "make:icons": "node scripts/make-icons.mjs",
    "package:mac": "node scripts/package-mac.mjs",
    "install:mac": "node scripts/package-mac.mjs --install"
  },
  "devDependencies": {
    "electron": "^42.5.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^5.65.21",
    "katex": "^0.17.0",
    "material-icon-theme": "^5.36.1",
    "pdfjs-dist": "^4.10.38"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  }
}
